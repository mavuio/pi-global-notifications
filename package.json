{
  "name": "pi-global-notifications",
  "version": "1.0.0",
  "description": "Pi extension: simple global notifications shared across local Pi sessions",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "notifications"
  ],
  "license": "MIT",
  "author": "Manfred Wuits",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavuio/pi-global-notifications.git"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./global-notifications.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
